+  tcb_set_state(new_cur_pid, TSTATE_RUN);
+  set_curid(new_cur_pid);
+
+  spinlock_release(&sched_lk);
+  kctx_switch(old_cur_pid, new_cur_pid);
+  // Should never return here
+}
