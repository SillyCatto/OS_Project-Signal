+/* Signal system calls */
+
+static gcc_inline int
+sys_sigaction(int signum, const struct sigaction *act, struct sigaction *oldact)
+{
+	int errno;
+	asm volatile ("int %1"
+		      : "=a" (errno)
+		      : "i" (T_SYSCALL),
+		        "a" (SYS_sigaction),
+		        "b" (signum),
+		        "c" (act),
+		        "d" (oldact)
+		      : "cc", "memory");
+	return errno ? -1 : 0;
+}
+
+static gcc_inline int
+sys_kill(int pid, int signum)
+{
+	int errno;
+	asm volatile ("int %1"
+		      : "=a" (errno)
+		      : "i" (T_SYSCALL),
+		        "a" (SYS_kill),
+		        "b" (pid),
+		        "c" (signum)
+		      : "cc", "memory");
+	return errno ? -1 : 0;
+}
+
+static gcc_inline int
+sys_pause(void)
+{
+	int errno;
+	asm volatile ("int %1"
+		      : "=a" (errno)
+		      : "i" (T_SYSCALL),
+		        "a" (SYS_pause)
+		      : "cc", "memory");
+	return errno ? -1 : 0;
+}
