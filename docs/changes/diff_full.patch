+{
+  if (signum >= 0 && signum < NSIG) {
+    TCBPool[pid].sigstate.pending_signals |= (1 << signum);
+  }
+}
+
+void tcb_clear_pending_signal(unsigned int pid, int signum)
+{
+  if (signum >= 0 && signum < NSIG) {
+    TCBPool[pid].sigstate.pending_signals &= ~(1 << signum);
+  }
